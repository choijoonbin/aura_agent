APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8010
STREAMLIT_PORT=8502

DATABASE_URL=postgresql://dwp_user:dwp_password@localhost:5432/dwp_aura
DEFAULT_TENANT_ID=1
DEFAULT_USER_ID=1
API_BASE_URL=http://localhost:8010

AURA_PLATFORM_PATH=/Users/joonbinchoi/Work/dwp/aura-platform
DWP_BACKEND_PATH=/Users/joonbinchoi/Work/dwp/dwp-backend
DWP_FRONTEND_PATH=/Users/joonbinchoi/Work/dwp/dwp-frontend

# Agent runtime mode
# native: MaterTask 내부 자율형 에이전트 우선
# aura: 향후 필요 시 legacy aura 전용 모드로 확장 가능
# hybrid: 향후 native + aura 병행 검증 모드로 확장 가능
AGENT_RUNTIME_MODE=langgraph

# 멀티 에이전트 역할 분리 활성화 여부
ENABLE_MULTI_AGENT=true

# langgraph 설치 시 향후 StateGraph 런타임으로 승격할 수 있도록 예약된 플래그
ENABLE_LANGGRAPH_IF_AVAILABLE=true

# PoC는 기본적으로 독립 실행형으로 동작합니다.
# true면 legacy Aura 심층 분석 specialist를 호출하며, 이 경로는 기존 Aura 내부에서 Synapse 연동을 시도할 수 있습니다.
# 독립 PoC 시연에서는 false 유지 권장.
ENABLE_LEGACY_AURA_SPECIALIST=false

# Reasoning 실시간 LLM 토큰 스트림(v2 미완 항목)
# true면 노드 reasoning을 OpenAI stream=True(JSON)로 생성하며 THINKING_TOKEN을 실시간 전송
ENABLE_REASONING_LIVE_LLM=true
REASONING_LLM_MODEL=gpt-5
REASONING_LLM_LABEL=OpenAI gpt-5
OPENAI_API_KEY=
# 필요 시 OpenAI 호환 엔드포인트 지정 (예: Azure/OpenRouter)
OPENAI_BASE_URL=
# Azure OpenAI 사용 시 API 버전 (기본값)
OPENAI_API_VERSION=2024-12-01-preview

# RAG 임베딩(OpenAI/Azure) 기본 설정
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIM=3072
RAG_EMBEDDING_COLUMN=embedding_az
RAG_EMBEDDING_CAST_TYPE=halfvec
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_EMBEDDING_MAX_RETRIES=3

# Langfuse (선택) - 테스트/분석 시 실행 로그를 Langfuse 대시보드에서 모니터링
# https://cloud.langfuse.com 에서 키 발급 후 설정
# LANGFUSE_ENABLED=true 로 설정해야 추적 전송
# LANGFUSE_ENABLED=false 이면 전송 안 함 (기본값)
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-35f72b71-aa65-4e18-b25b-95d2cd7e7fe8
LANGFUSE_SECRET_KEY=sk-lf-8aa88fcd-5549-403c-9da8-07d7965b374b
LANGFUSE_HOST=https://cloud.langfuse.com

# MCC 위험 분류 (screener·merchant_risk_probe 단일 소스, 쉼표 구분)
MCC_HIGH_RISK=5813,7993,7994,5912,7992,5999
MCC_LEISURE=7996,7997,7941,7011
MCC_MEDIUM_RISK=5812,5811,5814,4722
# MCC 로딩 소스: env | json | db
MCC_SOURCE=env
# MCC_SOURCE=json 일 때 사용 (예: {"high_risk":["5813"],"leisure":["7997"],"medium_risk":["5812"]})
MCC_JSON_PATH=
# MCC_SOURCE=db 일 때 사용 (예상 스키마: mcc_code, risk_level[HIGH|LEISURE|MEDIUM])
MCC_DB_TABLE=dwp_aura.mcc_risk_policy

# Planner: LLM 기반 도구 순서 결정 (false면 _plan_from_flags 규칙 사용)
ENABLE_LLM_PLANNER=true

# Execute: 독립 도구 병렬 실행 (policy_rulebook_probe·legacy는 순차)
ENABLE_PARALLEL_TOOL_EXECUTION=true

# Checkpointer: memory(개발) | postgres(운영, HITL 재시작 후 resume)
CHECKPOINTER_BACKEND=memory
