APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8010
STREAMLIT_PORT=8502

DATABASE_URL=postgresql://dwp_user:dwp_password@localhost:5432/dwp_aura
DEFAULT_TENANT_ID=1
DEFAULT_USER_ID=1
API_BASE_URL=http://localhost:8010

AURA_PLATFORM_PATH=/Users/joonbinchoi/Work/dwp/aura-platform
DWP_BACKEND_PATH=/Users/joonbinchoi/Work/dwp/dwp-backend
DWP_FRONTEND_PATH=/Users/joonbinchoi/Work/dwp/dwp-frontend

# Agent runtime mode
# native: MaterTask 내부 자율형 에이전트 우선
# aura: 향후 필요 시 legacy aura 전용 모드로 확장 가능
# hybrid: 향후 native + aura 병행 검증 모드로 확장 가능
AGENT_RUNTIME_MODE=langgraph

# 멀티 에이전트 역할 분리 활성화 여부
ENABLE_MULTI_AGENT=true

# langgraph 설치 시 향후 StateGraph 런타임으로 승격할 수 있도록 예약된 플래그
ENABLE_LANGGRAPH_IF_AVAILABLE=true
